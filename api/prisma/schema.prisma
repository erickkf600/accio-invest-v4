generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum AssetType {
  ACOES
  FII
  BDR
  ETF
  CRIPTO
}

enum OperationType {
  Compra
  Venda
  Proventos
}

model Asset {
  id        Int      @id @default(autoincrement())
  ticker    String   @unique @db.VarChar(20)
  tipo      AssetType
  nome      String?  @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  positions          PortfolioPosition[]
  operations         Operation[]

  fixedIncomePos     FixedIncomePosition[]
}

model PortfolioPosition {
  id         Int    @id @default(autoincrement())
  assetId    Int    @unique @map("asset_id")
  ticker     String @db.VarChar(20)
  qtd        Int
  precoMedio Float  @map("preco_medio")
  custoTotal Float  @map("custo_total")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id])

  @@map("portfolio_positions")
}

model Operation {
  id             Int           @id @default(autoincrement())
  assetId        Int           @map("asset_id")
  ticker         String        @db.VarChar(20)
  tipo           OperationType
  data           DateTime
  qtd            Int?
  precoUn        Float         @map("preco_unitario")
  taxas          Float?        @default(0)
  total          Float
  lucroRealizado Float?        @map("lucro_realizado")
  createdAt      DateTime      @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@index([ticker])
  @@map("operations")
}

model Repositioning {
  id           Int      @id @default(autoincrement())
  ticker       String   @db.VarChar(20)
  dataOperacao DateTime @map("data_operacao")
  tipo         String   @db.VarChar(20)
  fator        String   @db.VarChar(20)
  ratioDe      String   @db.VarChar(10) @map("ratio_de")
  ratioPara    String   @db.VarChar(10) @map("ratio_para")
  observacoes  String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("repositionings")
}

model FixedIncomePosition {
  id             Int      @id @default(autoincrement())
  emissor        String   @db.VarChar(200)
  tipo           String   @db.VarChar(20)
  indexador      String   @db.VarChar(10)
  taxaJuros      Float    @map("taxa_juros")
  liquidezDiaria Boolean  @map("liquidez_diaria")
  possuiImposto  Boolean  @map("possui_imposto")
  valorAplicado  Float    @map("valor_aplicado")
  dataCompra     DateTime @map("data_compra")
  vencimento     DateTime?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  assetId Int?  @map("asset_id")
  asset   Asset? @relation(fields: [assetId], references: [id])

  @@map("fixed_income_positions")
}

model FixedIncomeHistory {
  id              Int      @id @default(autoincrement())
  emissor         String   @db.VarChar(200)
  tipo            String   @db.VarChar(20)
  indexador       String   @db.VarChar(10)
  taxaJuros       Float    @map("taxa_juros")
  valorAplicado   Float    @map("valor_aplicado")
  valorResgate    Float    @map("valor_resgate")
  rendimentoBruto Float    @map("rendimento_bruto")
  impostoRetido   Float?   @map("imposto_retido")
  dataVencimento  DateTime @map("data_vencimento")
  dataResgate     DateTime @map("data_resgate")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("fixed_income_history")
}
